      <p>Päivitetty: 2026-06-14</p>
    </section>

    <section class="feedback">
      <h2>Onko tieto muuttunut?</h2>
      <form method="POST" action="/api/feedback">
        <input type="hidden" name="country" value="Ruotsi">
        <input placeholder="Nimi / nimimerkki" name="name">
        <input placeholder="Sähköposti" name="email" type="email">
        <textarea placeholder="Kommentti ja lähde" name="message" required></textarea>
        <input type="text" name="website" style="display:none">
        <div class="cf-turnstile" data-sitekey="0x4AAAAAADkh75wsb6atR_qi"></div>
        <button>Lähetä tarkistettavaksi</button>
      </form>
